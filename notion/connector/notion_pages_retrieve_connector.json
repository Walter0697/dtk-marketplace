{
  "id": "notion_pages_retrieve_connector",
  "name": "notion_pages_retrieve_connector",
  "source": "notion",
  "request": "curl -sS https://api.notion.com/v1/pages/<page_id> -H \"Authorization: Bearer $NOTION_CONNECTOR_TOKEN\" -H \"Notion-Version: 2026-03-11\"",
  "format": "json",
  "notes": "Keep only the identifiers and title text needed to recognize a shared page retrieve.",
  "allow": [
    "object",
    "id",
    "url",
    "properties.title.id",
    "properties.title.type",
    "properties.title.title[].plain_text"
  ],
  "hook_rule": {
    "command_prefix": "curl",
    "command_contains": [
      "api.notion.com/v1/pages/",
      "$NOTION_CONNECTOR_TOKEN"
    ]
  }
}
