{
  "id": "n8n_workflow_detail",
  "name": "n8n_workflow_detail",
  "source": "n8n",
  "request": "curl -sS -H \"X-N8N-API-KEY: $N8N_API_TOKEN\" \"${N8N_BASE_URL%/}/api/v1/workflows/<workflow_id>\"",
  "format": "json",
  "notes": "Keep workflow metadata plus a compact structural view of the nodes and wiring, while trimming the large nested parameter payloads in the active draft snapshot.",
  "allow": [
    "id",
    "name",
    "description",
    "active",
    "isArchived",
    "createdAt",
    "updatedAt",
    "versionId",
    "versionCounter",
    "activeVersionId",
    "triggerCount",
    "settings.executionOrder",
    "settings.binaryMode",
    "meta",
    "tags[].id",
    "tags[].name",
    "shared[].role",
    "shared[].workflowId",
    "shared[].projectId",
    "nodes[].id",
    "nodes[].name",
    "nodes[].type",
    "nodes[].typeVersion",
    "nodes[].position",
    "nodes[].parameters",
    "connections",
    "activeVersion.versionId",
    "activeVersion.name",
    "activeVersion.description",
    "activeVersion.active",
    "activeVersion.isArchived",
    "activeVersion.createdAt",
    "activeVersion.updatedAt",
    "activeVersion.versionId",
    "activeVersion.versionCounter",
    "activeVersion.settings.executionOrder",
    "activeVersion.settings.binaryMode",
    "activeVersion.nodes[].id",
    "activeVersion.nodes[].name",
    "activeVersion.nodes[].type",
    "activeVersion.nodes[].typeVersion",
    "activeVersion.nodes[].position",
    "activeVersion.nodes[].parameters",
    "activeVersion.connections"
  ]
}
