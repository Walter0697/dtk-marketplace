{
  "id": "github_commits_list",
  "name": "github_commits_list",
  "source": "github",
  "request": "curl -sS \"https://api.github.com/repos/rust-lang/rust/commits?per_page=5\"",
  "format": "json",
  "notes": "Keep commit identity, message, authorship, verification, and web URL.",
  "allow": ["[].sha", "[].html_url", "[].commit.message", "[].commit.author.name", "[].commit.author.email", "[].commit.author.date", "[].commit.committer.name", "[].commit.committer.date", "[].commit.verification.verified", "[].commit.verification.reason", "[].author.login", "[].committer.login"]
}
