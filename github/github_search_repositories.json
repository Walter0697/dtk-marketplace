{
  "id": "github_search_repositories",
  "name": "github_search_repositories",
  "source": "github",
  "request": "curl -sS \"https://api.github.com/search/repositories?q=language:rust&per_page=5\"",
  "format": "json",
  "notes": "Keep repository search identity, status, popularity, language, license, topics, timestamps, and web URL.",
  "content_path": "items",
  "allow": ["[].id", "[].full_name", "[].description", "[].html_url", "[].homepage", "[].private", "[].fork", "[].archived", "[].disabled", "[].visibility", "[].default_branch", "[].language", "[].license.spdx_id", "[].topics", "[].stargazers_count", "[].watchers_count", "[].forks_count", "[].open_issues_count", "[].created_at", "[].updated_at", "[].pushed_at"]
}
