{
  "id": "github_user_or_org_detail",
  "name": "github_user_or_org_detail",
  "source": "github",
  "request": "curl -sS \"https://api.github.com/users/octocat\"",
  "format": "json",
  "notes": "Keep public user/organization identity, profile, counts, verification, and timestamps.",
  "allow": [
    "id",
    "login",
    "name",
    "type",
    "html_url",
    "company",
    "blog",
    "location",
    "email",
    "hireable",
    "bio",
    "twitter_username",
    "description",
    "is_verified",
    "followers",
    "following",
    "public_repos",
    "public_gists",
    "created_at",
    "updated_at"
  ],
  "hook_rule": {
    "command_prefix": "curl",
    "command_contains": [
      "api.github.com/users/"
    ]
  }
}
