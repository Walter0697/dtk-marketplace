{
  "id": "github_branches_list",
  "name": "github_branches_list",
  "source": "github",
  "request": "curl -sS \"https://api.github.com/repos/rust-lang/rust/branches?per_page=5\"",
  "format": "json",
  "notes": "Keep branch name, commit SHA, and protection state.",
  "allow": ["[].name", "[].commit.sha", "[].protected"]
}
