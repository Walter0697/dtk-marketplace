{
  "id": "hackernews_algolia_item_root",
  "name": "hackernews_algolia_item_root",
  "source": "hackernews_algolia",
  "request": "curl -sS \"https://hn.algolia.com/api/v1/items/8863\"",
  "format": "json",
  "notes": "Compact HN Algolia item endpoint. Keep the root story/comment fields and drop the nested comment tree; retrieve original when full comments are needed.",
  "allow": [
    "id",
    "type",
    "title",
    "url",
    "author",
    "points",
    "story_id",
    "created_at",
    "created_at_i",
    "text"
  ],
  "hook_rule": {
    "command_prefix": "curl",
    "command_contains": [
      "hn.algolia.com/api/v1/items/"
    ]
  }
}
